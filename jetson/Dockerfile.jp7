# =============================================================================
# Unified Jetson AI + Robotics container — JetPack 7 (L4T r38/r39, Ubuntu 24.04, Python 3.12)
#
# Successor to ./Dockerfile (which targets JetPack 6 via nvcr.io/.../pytorch:24.12-py3-igpu)
# and the deployed image cmpelkk/jetson-llm:latest.
#
# Goals for this image (the "next-gen all-in-one"):
#   1. Feature-parity with cmpelkk/jetson-llm  (PyTorch · cv2 · ultralytics · transformers ·
#      huggingface · llama.cpp+CUDA · llama-cpp-python · Ollama · jupyterlab · fastapi · Node 20)
#   2. + LeRobot · RealSense · PyAV / FFmpeg-Python  for the robotics/vision lessons.
#   3. + Hardware-accelerated camera & video via GStreamer:
#        - libgstreamer + tools installed inside the container
#        - OpenCV REBUILT with WITH_GSTREAMER=ON  (default; off via --build-arg REBUILD_OPENCV=0)
#        - At runtime, --runtime nvidia auto-mounts the host's NV GStreamer plugins
#          (libgstnvarguscamerasrc / libgstnvv4l2camerasrc / libgstnvv4l2decoder /
#           libgstnvvidconv / libgstnvjpeg, plus the libnvargus/libnvbufsurface/libnvv4l2/
#           libnvjpeg backing libs in /usr/lib/aarch64-linux-gnu/nvidia/).
#          → after rebuild, `cv2.VideoCapture("nvarguscamerasrc ! ... ! appsink", cv2.CAP_GSTREAMER)`
#            and `cv2.VideoCapture("rtsp://…")` Just Work from Python, on the dedicated
#            NVENC/NVDEC hardware blocks (≈0% CPU vs ~30% software).
#
# BASE IMAGE — the one decision that matters most.
#   JetPack-7-native PyTorch bases are NOT published yet (dustynv/pytorch tops out at r36.4;
#   the jetson-ai-lab pip index has no jp7 channel). But NVIDIA's NGC "igpu" PyTorch images run
#   on JetPack 7 via CUDA forward-compat (verified on jetson61, JetPack 7 / L4T r39).
#   We base on a *recent* igpu tag whose torch satisfies LeRobot (torch>=2.7, torchvision>=0.22):
#       24.12-py3-igpu -> torch 2.6           (TOO OLD for lerobot 0.5.x)
#       25.02-py3-igpu -> torch 2.7
#       25.06-py3-igpu -> torch 2.8
#       25.08-py3-igpu -> torch 2.8.0a0 / torchvision 0.23.0a0 / CUDA 12.9 / TRT 10.11  (DEFAULT)
#   Confirm exact versions after build with:
#       docker run --rm --runtime nvidia <img> python -c \
#         "import torch,torchvision,cv2;print(torch.__version__,torchvision.__version__,
#          torch.version.cuda,cv2.__version__)"
# =============================================================================
ARG BASE_IMAGE=nvcr.io/nvidia/pytorch:25.08-py3-igpu
FROM ${BASE_IMAGE}

LABEL maintainer="kaikai.liu@sjsu.edu"
LABEL org.opencontainers.image.title="cmpelkk/jetson-unified"
LABEL org.opencontainers.image.description="Next-gen unified Jetson AI+robotics+LLM container (JP7 / L4T r39)"
LABEL org.opencontainers.image.source="https://github.com/lkk688/edgeAI/blob/main/jetson/Dockerfile.jp7"

ENV DEBIAN_FRONTEND=noninteractive
ENV PATH="/root/.local/bin:/usr/local/bin:$PATH"
# Jetson unified memory: reduce fragmentation/OOM for big models
ENV PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
# Pretty pip progress in non-TTY builds
ENV PIP_DISABLE_PIP_VERSION_CHECK=1

# Ports:
#  3000=Next.js Agent Lab UI    8001=generic FastAPI       8765/8766=SO-ARM101 teleop
#  8002=Agent FastAPI sidecar   8080=llama.cpp server      8888=JupyterLab
#  11434=Ollama
EXPOSE 3000 8001 8002 8080 8765 8766 8888 11434

# ============================================================================
# 1. System deps  (apt — small, stable layer that caches well)
# ============================================================================
# Block A — build/dev tools + python venv (existing)
# Block B — GStreamer stack (NEW): runtime + dev so OpenCV can link against it.
#           The NV plugins (libgstnv*.so) are NOT installed here — they are
#           bind-mounted in by --runtime nvidia at start via drivers.csv.
# Block C — FFmpeg dev + V4L runtime (NEW): video file I/O + V4L2 ioctls.
# Block D — display/X11 (NEW): so cv2.imshow works under SSH -X or VNC.
# Block E — Node.js 20 (NEW): bakes in the Next.js Agent Lab dependency so
#           `sjsujetsontool node` doesn't have to apt-install at runtime.
RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential git cmake ninja-build pkg-config curl wget ca-certificates gnupg \
      python3-venv python-is-python3 \
      libusb-1.0-0 libgl1 libglib2.0-0 v4l-utils \
      \
      libgstreamer1.0-0 libgstreamer-plugins-base1.0-0 \
      libgstreamer-plugins-bad1.0-0 libgstreamer-plugins-good1.0-0 \
      libgstreamer1.0-dev libgstreamer-plugins-base1.0-dev \
      gstreamer1.0-tools gstreamer1.0-plugins-base gstreamer1.0-plugins-good \
      gstreamer1.0-plugins-bad gstreamer1.0-plugins-ugly gstreamer1.0-libav \
      \
      ffmpeg libavcodec-dev libavformat-dev libswscale-dev libavutil-dev \
      libavfilter-dev libavdevice-dev libv4l-dev \
      \
      libgtk-3-0 libxcb-xinerama0 libxkbcommon-x11-0 x11-apps xauth \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/* /var/cache/apt/*

RUN pip install --upgrade pip

# ============================================================================
# 2. Pin the base's CUDA torch/torchvision  (critical — see comment)
# ============================================================================
# Generated FROM the base image itself. Every subsequent pip install honors
# this constraint, so no transitive dep can swap the CUDA torch wheel for a
# PyPI CPU wheel. If a package later demands newer torch than the base ships,
# the build FAILS LOUDLY here — bump BASE_IMAGE, do not ship a CPU image.
RUN python -c "import torch,torchvision; \
open('/opt/torch-constraints.txt','w').write( \
'torch==%s\ntorchvision==%s\n' % (torch.__version__.split('+')[0], torchvision.__version__.split('+')[0]))" \
 && echo "== torch constraints ==" && cat /opt/torch-constraints.txt
ENV PIP_CONSTRAINT=/opt/torch-constraints.txt

# ============================================================================
# 3. ML / NLP / LLM Python stack  (matches cmpelkk/jetson-llm + extras)
# ============================================================================
RUN pip install \
      numpy pandas matplotlib scipy scikit-learn tqdm tabulate requests \
      huggingface_hub transformers sentence-transformers accelerate datasets \
      langchain peft bitsandbytes optimum \
      fastapi uvicorn[standard] httpx sse-starlette pydantic \
      jupyterlab ipywidgets jupyter-server-proxy \
      gradio gradio-client \
      soundfile librosa "av>=12"

# ============================================================================
# 4. Vision: Ultralytics YOLO + COCO tooling
# ============================================================================
RUN pip install ultralytics pycocotools

# ============================================================================
# 5. Robotics: LeRobot (+Feetech servos) + Intel RealSense + gamepad
# ============================================================================
RUN pip install "lerobot[feetech]" pyrealsense2 pygame

# ============================================================================
# 6. numpy: an unavoidable tradeoff on this base
# ============================================================================
# The base's torch-tensorrt pins numpy<2 (on tegra), while lerobot 0.5.1 / rerun-sdk
# want numpy>=2 — mutually unsatisfiable. We choose numpy<2 to keep the prebuilt CUDA
# wheels (torch / torchvision / torch-tensorrt / opencv) on their native 1.x ABI.
# VERIFIED: with numpy 1.26.4 the GPU stack + lerobot CLI + ultralytics all work; the
# only casualty is rerun-sdk visualization. If you NEED rerun viz, replace this with
#   RUN pip install "numpy<2.3,>=2.0"
# and re-test torch/opencv imports (torch 2.8 supports numpy 2; torch-tensorrt won't).
RUN pip install "numpy<2"

# ============================================================================
# 7. OpenCV rebuild — WITH_GSTREAMER=ON, WITH_FFMPEG=ON, WITH_CUDA=ON
# ============================================================================
# WHY rebuild: the pip-installed opencv-python from the base has FFMPEG=YES but
# GStreamer=NO and no CUDA. We need GStreamer so cv2 can drive the NV hardware
# pipelines (nvarguscamerasrc / nvv4l2decoder / nvvidconv) that --runtime nvidia
# auto-mounts. CUDA support also gives us cv2.cuda_GpuMat for zero-copy ops.
#
# COST: ~25-40 min on Jetson Orin (single-stage so the final image is self-contained).
# Toggle off with --build-arg REBUILD_OPENCV=0 if you just need the apt-installed
# gstreamer tools but not cv2 GStreamer support (saves ~35 min).
ARG REBUILD_OPENCV=1
ARG OPENCV_VERSION=4.10.0
# CUDA arch: 8.7 = Orin; 7.2 = Xavier. If you also target Xavier, set "7.2;8.7".
ARG OPENCV_CUDA_ARCH_BIN=8.7
RUN if [ "$REBUILD_OPENCV" = "1" ]; then \
      pip uninstall -y opencv-python opencv-python-headless opencv-contrib-python || true && \
      cd /tmp && \
      curl -fsSL -o opencv.tar.gz \
        "https://github.com/opencv/opencv/archive/refs/tags/${OPENCV_VERSION}.tar.gz" && \
      curl -fsSL -o opencv_contrib.tar.gz \
        "https://github.com/opencv/opencv_contrib/archive/refs/tags/${OPENCV_VERSION}.tar.gz" && \
      tar xzf opencv.tar.gz && tar xzf opencv_contrib.tar.gz && \
      cd opencv-${OPENCV_VERSION} && mkdir build && cd build && \
      cmake -GNinja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DOPENCV_EXTRA_MODULES_PATH=/tmp/opencv_contrib-${OPENCV_VERSION}/modules \
        -DWITH_GSTREAMER=ON \
        -DWITH_FFMPEG=ON \
        -DWITH_V4L=ON -DWITH_LIBV4L=ON \
        -DWITH_CUDA=ON -DCUDA_ARCH_BIN=${OPENCV_CUDA_ARCH_BIN} \
        -DENABLE_FAST_MATH=ON -DCUDA_FAST_MATH=ON \
        -DWITH_CUBLAS=ON -DWITH_CUDNN=ON -DOPENCV_DNN_CUDA=ON \
        -DWITH_GTK=OFF -DWITH_QT=OFF \
        -DBUILD_EXAMPLES=OFF -DBUILD_TESTS=OFF -DBUILD_PERF_TESTS=OFF -DBUILD_DOCS=OFF \
        -DBUILD_opencv_python3=ON \
        -DPYTHON3_EXECUTABLE=$(which python3) \
        -DOPENCV_PYTHON3_INSTALL_PATH=$(python3 -c "import sysconfig; print(sysconfig.get_paths()['purelib'])") \
        -DOPENCV_GENERATE_PKGCONFIG=ON \
        .. && \
      ninja -j"$(nproc)" && ninja install && ldconfig && \
      cd / && rm -rf /tmp/opencv-${OPENCV_VERSION} /tmp/opencv_contrib-${OPENCV_VERSION} \
                     /tmp/opencv.tar.gz /tmp/opencv_contrib.tar.gz ; \
    fi

# ============================================================================
# 8. llama.cpp + Ollama  (default — used by `sjsujetsontool llama` / `chat --local`)
# ============================================================================
# Was --build-arg INSTALL_LLAMACPP=1 in the old jp7 file; now DEFAULT to match
# the deployed cmpelkk/jetson-llm image. Toggle off with --build-arg INSTALL_LLAMACPP=0.
ARG INSTALL_LLAMACPP=1
RUN if [ "$INSTALL_LLAMACPP" = "1" ]; then \
      git clone --depth=1 https://github.com/ggerganov/llama.cpp.git /opt/llama.cpp && \
      cmake -S /opt/llama.cpp -B /opt/llama.cpp/build -DGGML_CUDA=ON -DGGML_NATIVE=OFF && \
      cmake --build /opt/llama.cpp/build --config Release -j"$(nproc)" && \
      ln -sf /opt/llama.cpp/build/bin/llama-cli   /usr/local/bin/llama-cli && \
      ln -sf /opt/llama.cpp/build/bin/llama-server /usr/local/bin/llama-server && \
      CMAKE_ARGS="-DGGML_CUDA=on" pip install --no-cache-dir llama-cpp-python && \
      curl -fsSL https://ollama.com/download/ollama-linux-arm64 -o /usr/local/bin/ollama && \
      chmod +x /usr/local/bin/ollama ; \
    fi

# ============================================================================
# 9. OPTIONAL: ROS 2 Jazzy (Ubuntu 24.04)  — adds ~1.5 GB
# ============================================================================
ARG INSTALL_ROS=0
RUN if [ "$INSTALL_ROS" = "1" ]; then \
      curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key \
           -o /usr/share/keyrings/ros-archive-keyring.gpg && \
      echo "deb [signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] http://packages.ros.org/ros2/ubuntu noble main" \
           > /etc/apt/sources.list.d/ros2.list && \
      apt-get update && apt-get install -y --no-install-recommends \
        ros-jazzy-ros-base ros-jazzy-vision-msgs ros-jazzy-cv-bridge ros-jazzy-image-publisher && \
      rm -rf /var/lib/apt/lists/* && \
      echo "source /opt/ros/jazzy/setup.bash" >> /root/.bashrc ; \
    fi

# ============================================================================
# 10. Cache + workspace + default model dirs (sjsujetsontool convention)
# ============================================================================
RUN mkdir -p /models /Developer/models /root/.cache /workspace
# Mirror the env the existing image uses, so caches land on the host SSD when
# /Developer is bind-mounted in (sjsujetsontool already does this).
ENV HF_HOME=/Developer/models/huggingface \
    HF_HUB_CACHE=/Developer/models/huggingface/hub \
    LLAMA_CACHE=/Developer/models/llama_cache \
    TORCH_HOME=/Developer/models/torch
WORKDIR /workspace

# ============================================================================
# 11. Build-time sanity check
# ============================================================================
# docker build has no GPU, so we verify:
#   - torch is a CUDA *build* (cuda.is_available() needs --runtime nvidia at run-time)
#   - cv2 has the right backends after the rebuild  (GStreamer YES when REBUILD_OPENCV=1)
# CI / classroom build will fail loudly here on regressions.
RUN python - <<'PY'
import torch, torchvision, numpy, cv2, ultralytics, lerobot, transformers, fastapi
assert torch.version.cuda and '+cpu' not in torch.__version__, \
    'torch is not a CUDA build — bump BASE_IMAGE'
info = cv2.getBuildInformation()
gst   = next((l for l in info.splitlines() if 'GStreamer' in l), '')
ffm   = next((l for l in info.splitlines() if 'FFMPEG'    in l), '')
print('OK | torch',        torch.__version__,
      '| tv',              torchvision.__version__,
      '| cuda',            torch.version.cuda,
      '| numpy',           numpy.__version__,
      '| cv2',             cv2.__version__,
      '| ultralytics',     ultralytics.__version__,
      '| lerobot',         lerobot.__version__,
      '| transformers',    transformers.__version__)
print('cv2 backends:', gst.strip(), '|', ffm.strip())
PY

# =============================================================================
# Build / push (run on a JetPack 7 Jetson, from the repo's jetson/ dir):
#
#   docker build -f Dockerfile.jp7 -t cmpelkk/jetson-unified:jp7 .
#
#   # skip the 30-min OpenCV rebuild (lose cv2 GStreamer support):
#   docker build -f Dockerfile.jp7 --build-arg REBUILD_OPENCV=0 -t cmpelkk/jetson-unified:jp7-mini .
#
#   # skip llama.cpp + Ollama:
#   docker build -f Dockerfile.jp7 --build-arg INSTALL_LLAMACPP=0 -t cmpelkk/jetson-unified:jp7-noLLM .
#
#   # also bake ROS 2 Jazzy in:
#   docker build -f Dockerfile.jp7 --build-arg INSTALL_ROS=1 -t cmpelkk/jetson-unified:jp7-ros .
#
#   # push to docker hub:
#   docker push cmpelkk/jetson-unified:jp7
#
# Run — the --runtime nvidia flag is REQUIRED for GStreamer NV plugins / CUDA:
#
#   docker run --rm -it --runtime nvidia --network host --ipc=host \
#     --ulimit memlock=-1 --ulimit stack=67108864 --shm-size=1g \
#     --device-cgroup-rule='c 81:* rmw' --device-cgroup-rule='c 14:* rmw' \
#     -v /dev:/dev -v /tmp/.X11-unix:/tmp/.X11-unix \
#     -v /Developer:/Developer \
#     -e DISPLAY=$DISPLAY \
#     cmpelkk/jetson-unified:jp7
#
# Verify CUDA + GStreamer + camera at runtime:
#
#   # 1) torch / cuda
#   python -c "import torch; print('cuda', torch.cuda.is_available(),
#                                   torch.cuda.get_device_name(0))"
#
#   # 2) GStreamer NV plugins auto-mounted by --runtime nvidia
#   gst-inspect-1.0 nvarguscamerasrc nvv4l2camerasrc nvv4l2decoder | head
#
#   # 3) cv2 + GStreamer pipeline (USB cam through hardware path)
#   python -c "import cv2; \
#     p='nvv4l2camerasrc device=/dev/video0 ! video/x-raw(memory:NVMM),width=1280,height=720 ! \
#        nvvidconv ! video/x-raw,format=BGRx ! videoconvert ! appsink'; \
#     cap=cv2.VideoCapture(p, cv2.CAP_GSTREAMER); print('opened:', cap.isOpened()); \
#     ok,f=cap.read(); print('shape:', f.shape if ok else None)"
#
#   # 4) cv2 + RTSP (FFmpeg backend handles this)
#   python -c "import cv2; \
#     cap=cv2.VideoCapture('rtsp://your.cam/stream', cv2.CAP_FFMPEG); \
#     print('opened:', cap.isOpened())"
# =============================================================================
