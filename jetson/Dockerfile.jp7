# =============================================================================
# Unified Jetson AI + Robotics container — JetPack 7 (L4T r38/r39, Ubuntu 24.04, Python 3.12)
# Successor to ./Dockerfile (which targets JetPack 6 via nvcr.io/.../pytorch:24.12-py3-igpu).
#
# BASE IMAGE — the one decision that matters most.
#   JetPack-7-native PyTorch bases are NOT published yet (dustynv/pytorch tops out at r36.4;
#   the jetson-ai-lab pip index has no jp7 channel). But NVIDIA's NGC "igpu" PyTorch images run
#   on JetPack 7 via CUDA forward-compat (the 24.12-igpu image already does on our r39 boxes).
#   So we base on a *recent* igpu tag whose torch satisfies LeRobot (torch>=2.7, torchvision>=0.22):
#       24.12-py3-igpu -> torch 2.6           (TOO OLD for lerobot 0.5.x)
#       25.02-py3-igpu -> torch 2.7
#       25.06-py3-igpu -> torch 2.8
#       25.08-py3-igpu -> torch 2.8.0a0 / torchvision 0.23.0a0 / CUDA 12.9  (VERIFIED default)
#   VERIFIED on jetson61 (Orin, JetPack 7 / L4T r39): builds clean and at runtime
#   torch.cuda.is_available()=True, GPU YOLO (ultralytics) runs on cuda:0, lerobot 0.5.1
#   reports CUDA=True, and pyrealsense2 2.58 imports.
#   Confirm the exact versions against the NGC PyTorch release notes, or after build with:
#       docker run --rm --runtime nvidia <img> python -c \
#         "import torch,torchvision;print(torch.__version__,torchvision.__version__,torch.version.cuda)"
# =============================================================================
ARG BASE_IMAGE=nvcr.io/nvidia/pytorch:25.08-py3-igpu
FROM ${BASE_IMAGE}

LABEL maintainer="kaikai.liu@sjsu.edu"
ENV DEBIAN_FRONTEND=noninteractive
ENV PATH="/root/.local/bin:$PATH"
# Jetson unified memory: reduce fragmentation/OOM for big models
ENV PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# JupyterLab, Ollama, llama.cpp/vLLM, SO-ARM101 teleop UDP+HTTP
EXPOSE 8888 11434 8000 8765 8766

# ---- system deps -----------------------------------------------------------
#   libusb-1.0-0  : required by pyrealsense2 (else ImportError: libusb-1.0.so.0)
#   v4l-utils     : camera enumeration (v4l2-ctl) for LeRobot/CSI workflows
#   libgl1/glib   : OpenCV runtime
RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential git cmake curl wget ca-certificates gnupg \
      python3-venv python-is-python3 \
      libusb-1.0-0 libgl1 libglib2.0-0 v4l-utils \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --upgrade pip

# ---- PIN the base's CUDA torch/torchvision ---------------------------------
# Generated from the base image itself. Every pip install below uses this as a
# constraint, so no package can swap the CUDA build for a PyPI CPU wheel.
# If a package demands newer torch than the base provides, the build FAILS here
# (loudly) — that is the cue to bump BASE_IMAGE, not to ship a CPU image.
RUN python -c "import torch,torchvision; \
open('/opt/torch-constraints.txt','w').write( \
'torch==%s\ntorchvision==%s\n' % (torch.__version__.split('+')[0], torchvision.__version__.split('+')[0]))" \
 && echo "== torch constraints ==" && cat /opt/torch-constraints.txt
ENV PIP_CONSTRAINT=/opt/torch-constraints.txt

# ---- ML / NLP / LLM stack --------------------------------------------------
RUN pip install \
      numpy pandas matplotlib scipy scikit-learn tqdm tabulate requests \
      huggingface_hub transformers sentence-transformers accelerate datasets \
      langchain fastapi uvicorn jupyterlab

# ---- Vision: Ultralytics YOLO ----------------------------------------------
RUN pip install ultralytics

# ---- Robotics: LeRobot (+Feetech servos) + Intel RealSense + gamepad -------
RUN pip install "lerobot[feetech]" pyrealsense2 pygame

# ---- numpy: an unavoidable tradeoff on this base ---------------------------
# The base's torch-tensorrt pins numpy<2 (on tegra), while lerobot 0.5.1 / rerun-sdk
# want numpy>=2 — mutually unsatisfiable. We choose numpy<2 to keep the prebuilt CUDA
# wheels (torch / torchvision / torch-tensorrt / opencv) on their native 1.x ABI.
# VERIFIED: with numpy 1.26.4 the GPU stack + lerobot CLI + ultralytics all work; the
# only casualty is rerun-sdk visualization. If you NEED rerun viz, replace this with
#   RUN pip install "numpy<2.3,>=2.0"
# and re-test torch/opencv imports (torch 2.8 supports numpy 2; torch-tensorrt won't).
RUN pip install "numpy<2"

# ---- build-time sanity check ----------------------------------------------
# NOTE: docker build has no GPU, so we verify torch is a CUDA *build*
# (torch.version.cuda set, not a +cpu wheel) rather than cuda.is_available().
RUN python -c "import torch,torchvision,numpy,cv2,ultralytics,lerobot; \
assert torch.version.cuda and '+cpu' not in torch.__version__, 'torch is not a CUDA build — bump BASE_IMAGE'; \
print('OK | torch',torch.__version__,'| tv',torchvision.__version__,'| cuda',torch.version.cuda, \
'| numpy',numpy.__version__,'| cv2',cv2.__version__,'| ultralytics',ultralytics.__version__,'| lerobot',lerobot.__version__)"

# ---- OPTIONAL: ROS 2 Jazzy (Ubuntu 24.04) ----------------------------------
# Adds ~1.5 GB. Enable with:  --build-arg INSTALL_ROS=1
ARG INSTALL_ROS=0
RUN if [ "$INSTALL_ROS" = "1" ]; then \
      curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key \
           -o /usr/share/keyrings/ros-archive-keyring.gpg && \
      echo "deb [signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] http://packages.ros.org/ros2/ubuntu noble main" \
           > /etc/apt/sources.list.d/ros2.list && \
      apt-get update && apt-get install -y --no-install-recommends \
        ros-jazzy-ros-base ros-jazzy-vision-msgs ros-jazzy-cv-bridge ros-jazzy-image-publisher && \
      rm -rf /var/lib/apt/lists/* && \
      echo "source /opt/ros/jazzy/setup.bash" >> /root/.bashrc ; \
    fi

# ---- OPTIONAL: llama.cpp + Ollama (LLM serving, as in the jp6 image) -------
# Heavy; enable with:  --build-arg INSTALL_LLAMACPP=1
ARG INSTALL_LLAMACPP=0
RUN if [ "$INSTALL_LLAMACPP" = "1" ]; then \
      git clone --depth=1 https://github.com/ggerganov/llama.cpp.git /opt/llama.cpp && \
      cmake -S /opt/llama.cpp -B /opt/llama.cpp/build -DGGML_CUDA=ON && \
      cmake --build /opt/llama.cpp/build --config Release -j"$(nproc)" && \
      CMAKE_ARGS="-DGGML_CUDA=on" pip install llama-cpp-python && \
      curl -L https://ollama.com/download/ollama-linux-arm64 -o /usr/local/bin/ollama && \
      chmod +x /usr/local/bin/ollama ; \
    fi

RUN mkdir -p /models /root/.cache
WORKDIR /workspace

# =============================================================================
# Build (run on a JetPack 7 Jetson, from the repo's jetson/ dir):
#   docker build -f Dockerfile.jp7 -t jetson-unified:jp7 .
#   docker build -f Dockerfile.jp7 --build-arg INSTALL_ROS=1 -t jetson-unified:jp7-ros .
#   # try a newer/older torch base:
#   docker build -f Dockerfile.jp7 --build-arg BASE_IMAGE=nvcr.io/nvidia/pytorch:25.06-py3-igpu -t jetson-unified:jp7 .
#
# Run:
#   docker run --rm -it --runtime nvidia --network host --ipc=host \
#     -e NVIDIA_VISIBLE_DEVICES=all \
#     -v /Developer:/Developer -v /Developer/models:/models \
#     jetson-unified:jp7
#
# Verify CUDA at runtime (needs --runtime nvidia):
#   python -c "import torch;print('cuda',torch.cuda.is_available(),torch.cuda.get_device_name(0))"
# =============================================================================
