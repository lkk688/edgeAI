# Copy this file to .env.local and fill in your key.
# Get a free key at https://build.nvidia.com (click any model → "Get API Key").

NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default chat model the API route will call. Override per-request from the UI.
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# OpenAI-compatible base URL for NVIDIA Build (chat + embeddings).
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Embedding + rerank models used by /app/api/embed and /app/api/rerank.
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5
NVIDIA_RERANK_URL=https://ai.api.nvidia.com/v1/retrieval/nvidia/reranking
NVIDIA_RERANK_MODEL=nvidia/rerank-qa-mistral-4b

# Multimodal (image + audio) reasoning model used by /app/api/omni.
NVIDIA_OMNI_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# Streaming ASR via NVIDIA Build (Riva gRPC). The Next.js /api/asr route
# proxies to a Python sidecar that holds the gRPC connection; see
# asr_sidecar/asr_sidecar.py and asr_sidecar/README.md for how to run it.
ASR_SIDECAR_URL=http://localhost:8001
NEMOTRON_ASR_FUNCTION_ID=bb0837de-8c7b-481f-9ec8-ef5663e9c1fa
