# Required.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides — defaults are sensible for the tutorial.
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
TRIAGE_CODER_MODEL=minimaxai/minimax-m2.7
TRIAGE_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# Optional NVD API key (raises rate limit from 5 to 50 req per 30s).
# Free signup at https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=...
